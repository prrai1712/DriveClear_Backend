SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Option A: Local MySQL (default) ---
DB_NAME=driveclear
DB_USER=driveclear
DB_PASSWORD=driveclear
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Option B: Same DB as Render/production (uncomment ONE line; comment DB_* if you prefer) ---
# Copy "External Database URL" from Render → driveclear-mysql → Connect
# DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/DATABASE

REDIS_URL=redis://127.0.0.1:6379/0

CORS_ALLOWED_ORIGINS=http://localhost:3000

RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxx

# mock = OTP 123456 (no SMS) | msg91 = real SMS (free trial at msg91.com)
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=DRCLEAR
# Optional: create OTP template in MSG91 → use template id here
MSG91_TEMPLATE_ID=

# Firebase — PROJECT_ID enough for local token verify (matches frontend NEXT_PUBLIC_FIREBASE_PROJECT_ID)
FIREBASE_PROJECT_ID=driveclear-82af6
# Production optional: service account JSON
# FIREBASE_CREDENTIALS_PATH=firebase/driveclear-service-account.json
# FIREBASE_CREDENTIALS_JSON=
EXTERNAL_CHALLAN_API_URL=https://www.challanpay.in/api/d-to-c/user-verification
EXTERNAL_CHALLAN_FIND_URL=https://www.challanpay.in/api/d-to-c/find-challans
EXTERNAL_CHALLAN_UTM_SOURCE=challanpay
# Skip ChallanPay API for same vehicle_number within this many days (serve DB cache)
CHALLAN_FETCH_CACHE_DAYS=3

# Optional: encrypt API JSON bodies (AES-256-GCM). Same key in frontend NEXT_PUBLIC_* vars.
# Generate: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
API_PAYLOAD_ENCRYPTION_ENABLED=false
API_PAYLOAD_ENCRYPTION_KEY=
# all = every /api/v1 route | fetch_only = POST /challans/fetch/ only
API_PAYLOAD_ENCRYPTION_SCOPE=all
